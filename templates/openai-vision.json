{
  "version": 1,
  "variables": [
    {
      "name": "api_key",
      "source": "vault",
      "default_value": null,
      "description": "OpenAI API Key"
    },
    {
      "name": "model",
      "source": "config",
      "default_value": "gpt-4o",
      "description": "Model ID (e.g. gpt-4o, gpt-4o-mini)"
    }
  ],
  "steps": [
    {
      "name": "Vision Chat Completion",
      "method": "POST",
      "url": "https://api.openai.com/v1/chat/completions",
      "auth": {
        "auth_type": "bearer",
        "credential": "{{api_key}}"
      },
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ],
      "body": "{\n  \"model\": \"{{model}}\",\n  \"messages\": [\n    {\"role\": \"system\", \"content\": \"{{system_prompt}}\"},\n    {\"role\": \"user\", \"content\": [\n      {\"type\": \"text\", \"text\": \"{{prompt}}\"}{{#if has_image}},\n      {\"type\": \"image_url\", \"image_url\": {\"url\": \"data:image/png;base64,{{image_base64}}\"}}{{/if}}\n    ]}\n  ],\n  \"temperature\": {{temperature}}\n}",
      "body_content_type": "application/json",
      "extract": [
        {
          "variable_name": "result",
          "source": "body",
          "path": "choices[0].message.content"
        }
      ],
      "stream_path": null
    }
  ],
  "result_from": "steps.1.result"
}
