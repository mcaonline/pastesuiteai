{
  "version": 1,
  "variables": [
    {
      "name": "api_key",
      "source": "vault",
      "default_value": null,
      "description": "OpenAI API Key"
    },
    {
      "name": "model",
      "source": "config",
      "default_value": "gpt-4o",
      "description": "Model ID (e.g. gpt-4o, gpt-4o-mini, gpt-4-turbo)"
    }
  ],
  "steps": [
    {
      "name": "Streaming Chat Completion",
      "method": "POST",
      "url": "https://api.openai.com/v1/chat/completions",
      "auth": {
        "auth_type": "bearer",
        "credential": "{{api_key}}"
      },
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ],
      "body": "{\n  \"model\": \"{{model}}\",\n  \"messages\": [\n    {\"role\": \"system\", \"content\": \"{{system_prompt}}\"},\n    {\"role\": \"user\", \"content\": \"{{prompt}}\"}\n  ],\n  \"temperature\": {{temperature}},\n  \"stream\": true\n}",
      "body_content_type": "application/json",
      "extract": [
        {
          "variable_name": "result",
          "source": "body",
          "path": "streamed_content"
        }
      ],
      "stream_path": "choices[0].delta.content"
    }
  ],
  "result_from": "steps.1.result"
}
